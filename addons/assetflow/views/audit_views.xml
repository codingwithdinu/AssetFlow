<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Audit Tree -->
    <record id="view_assetflow_audit_tree" model="ir.ui.view">
        <field name="name">assetflow.audit.tree</field>
        <field name="model">assetflow.audit</field>
        <field name="arch" type="xml">
            <tree string="Audits">
                <field name="name"/>
                <field name="audit_date"/>
                <field name="conducted_by"/>
                <field name="department_id"/>
                <field name="total_assets"/>
                <field name="found_count"/>
                <field name="missing_count"/>
                <field name="damaged_count"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'completed'"/>
            </tree>
        </field>
    </record>

    <!-- Audit Form -->
    <record id="view_assetflow_audit_form" model="ir.ui.view">
        <field name="name">assetflow.audit.form</field>
        <field name="model">assetflow.audit</field>
        <field name="arch" type="xml">
            <form string="Asset Audit">
                <header>
                    <button name="action_load_assets" string="📋 Load Assets"
                            type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_start" string="▶ Start Audit"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_complete" string="✔ Complete Audit"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state', '!=', 'in_progress')]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="audit_date"/>
                            <field name="conducted_by"/>
                            <field name="department_id"/>
                        </group>
                        <group string="Summary">
                            <field name="total_assets" readonly="1"/>
                            <field name="found_count" readonly="1"/>
                            <field name="missing_count" readonly="1"/>
                            <field name="damaged_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Audit Lines" name="lines">
                            <field name="audit_line_ids">
                                <tree editable="bottom">
                                    <field name="asset_tag" readonly="1"/>
                                    <field name="asset_id"/>
                                    <field name="category_id" readonly="1"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'found'"
                                           decoration-danger="status == 'missing'"
                                           decoration-warning="status == 'damaged'"/>
                                    <field name="remarks"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_assetflow_audit" model="ir.actions.act_window">
        <field name="name">Audits</field>
        <field name="res_model">assetflow.audit</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
