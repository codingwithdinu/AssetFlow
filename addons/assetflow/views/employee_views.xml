<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Employee Tree -->
    <record id="view_assetflow_employee_tree" model="ir.ui.view">
        <field name="name">assetflow.employee.tree</field>
        <field name="model">assetflow.employee</field>
        <field name="arch" type="xml">
            <tree string="Employees">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_title"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="allocated_asset_count"/>
            </tree>
        </field>
    </record>

    <!-- Employee Form -->
    <record id="view_assetflow_employee_form" model="ir.ui.view">
        <field name="name">assetflow.employee.form</field>
        <field name="model">assetflow.employee</field>
        <field name="arch" type="xml">
            <form string="Employee">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Employee Name..."/></h1>
                        <h3><field name="job_title" placeholder="Job Title..."/></h3>
                    </div>
                    <group>
                        <group string="Personal Info">
                            <field name="employee_id"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Work Info">
                            <field name="department_id"/>
                            <field name="allocated_asset_count" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_assetflow_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">assetflow.employee</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
