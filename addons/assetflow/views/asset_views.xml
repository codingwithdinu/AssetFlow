<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ ASSET VIEWS ═══════════════════════════════════════════ -->

    <!-- List View -->
    <record id="view_assetflow_asset_tree" model="ir.ui.view">
        <field name="name">assetflow.asset.tree</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <tree string="Assets" decoration-success="state == 'available'"
                  decoration-warning="state == 'maintenance'"
                  decoration-danger="state in ('retired', 'lost')"
                  decoration-info="state == 'allocated'">
                <field name="asset_tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="brand"/>
                <field name="serial_number"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="purchase_date"/>
                <field name="warranty_status" widget="badge"
                       decoration-success="warranty_status == 'valid'"
                       decoration-danger="warranty_status == 'expired'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-info="state == 'allocated'"
                       decoration-warning="state == 'maintenance'"
                       decoration-danger="state in ('retired', 'lost')"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_assetflow_asset_form" model="ir.ui.view">
        <field name="name">assetflow.asset.form</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <button name="action_mark_available" string="Mark Available"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state', '=', 'available')]}"/>
                    <button name="action_mark_maintenance" string="Send to Maintenance"
                            type="object" class="btn-warning"
                            attrs="{'invisible': [('state', 'in', ['maintenance', 'retired'])]}"/>
                    <button name="action_retire" string="Retire Asset"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('state', '=', 'retired')]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,allocated,maintenance,retired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="asset_tag" class="oe_edit_only"/>
                        <h1>
                            <field name="asset_tag" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Asset Name..."/>
                        </h2>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="category_id"/>
                            <field name="serial_number"/>
                            <field name="brand"/>
                            <field name="model_number"/>
                        </group>
                        <group string="Assignment">
                            <field name="department_id"/>
                            <field name="employee_id"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group>
                        <group string="Financial">
                            <field name="purchase_date"/>
                            <field name="purchase_price"/>
                            <field name="warranty_expiry"/>
                            <field name="warranty_status" readonly="1"/>
                            <field name="age_years" readonly="1"/>
                            <field name="depreciation_rate"/>
                        </group>
                        <group string="Details">
                            <field name="description"/>
                            <field name="notes"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="History" name="history">
                            <field name="asset_history_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="action"/>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="performed_by"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_assetflow_asset_kanban" model="ir.ui.view">
        <field name="name">assetflow.asset.kanban</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="state">
                <field name="asset_tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="asset_tag"/></strong> –
                                <field name="name"/>
                                <div class="text-muted">
                                    <field name="category_id"/>
                                </div>
                                <div t-if="record.employee_id.value">
                                    👤 <field name="employee_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_assetflow_asset_search" model="ir.ui.view">
        <field name="name">assetflow.asset.search</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="name" string="Asset"/>
                <field name="asset_tag"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <filter string="Available" name="available"
                        domain="[('state', '=', 'available')]"/>
                <filter string="Allocated" name="allocated"
                        domain="[('state', '=', 'allocated')]"/>
                <filter string="Maintenance" name="maintenance"
                        domain="[('state', '=', 'maintenance')]"/>
                <filter string="Retired" name="retired"
                        domain="[('state', '=', 'retired')]"/>
                <separator/>
                <filter string="Warranty Expired" name="warranty_expired"
                        domain="[('warranty_status', '=', 'expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                    <filter string="Department" name="group_department"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_assetflow_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_assetflow_asset_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first asset!
            </p>
            <p>Track company assets from purchase to retirement.</p>
        </field>
    </record>

</odoo>
