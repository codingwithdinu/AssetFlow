<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════
         ASSETFLOW – MAIN MENU STRUCTURE
    ════════════════════════════════════════════════ -->

    <!-- Root Menu -->
    <menuitem id="menu_assetflow_root"
              name="AssetFlow"
              sequence="10"
              web_icon="assetflow,static/description/icon.png"
              groups="assetflow.group_assetflow_employee"/>

    <!-- Dashboard -->
    <menuitem id="menu_assetflow_dashboard"
              name="Dashboard"
              parent="menu_assetflow_root"
              action="action_assetflow_dashboard"
              sequence="1"
              groups="assetflow.group_assetflow_employee"/>

    <!-- Organization -->
    <menuitem id="menu_assetflow_organization"
              name="Organization"
              parent="menu_assetflow_root"
              sequence="2"
              groups="assetflow.group_assetflow_manager"/>

    <menuitem id="menu_assetflow_departments"
              name="Departments"
              parent="menu_assetflow_organization"
              action="action_assetflow_department"
              sequence="1"/>

    <menuitem id="menu_assetflow_employees"
              name="Employees"
              parent="menu_assetflow_organization"
              action="action_assetflow_employee"
              sequence="2"/>

    <!-- Assets -->
    <menuitem id="menu_assetflow_assets_root"
              name="Assets"
              parent="menu_assetflow_root"
              sequence="3"
              groups="assetflow.group_assetflow_employee"/>

    <menuitem id="menu_assetflow_categories"
              name="Categories"
              parent="menu_assetflow_assets_root"
              action="action_assetflow_category"
              sequence="1"
              groups="assetflow.group_assetflow_manager"/>

    <menuitem id="menu_assetflow_asset_list"
              name="All Assets"
              parent="menu_assetflow_assets_root"
              action="action_assetflow_asset"
              sequence="2"
              groups="assetflow.group_assetflow_manager"/>

    <menuitem id="menu_assetflow_allocation"
              name="Allocations"
              parent="menu_assetflow_assets_root"
              action="action_assetflow_allocation"
              sequence="3"
              groups="assetflow.group_assetflow_dept_head"/>

    <menuitem id="menu_assetflow_transfers"
              name="Transfers"
              parent="menu_assetflow_assets_root"
              action="action_assetflow_transfer"
              sequence="4"
              groups="assetflow.group_assetflow_dept_head"/>

    <!-- Resource Booking -->
    <menuitem id="menu_assetflow_booking"
              name="Resource Booking"
              parent="menu_assetflow_root"
              action="action_assetflow_booking"
              sequence="4"
              groups="assetflow.group_assetflow_employee"/>

    <!-- Maintenance -->
    <menuitem id="menu_assetflow_maintenance"
              name="Maintenance"
              parent="menu_assetflow_root"
              action="action_assetflow_maintenance"
              sequence="5"
              groups="assetflow.group_assetflow_employee"/>

    <!-- Audit -->
    <menuitem id="menu_assetflow_audit"
              name="Audit"
              parent="menu_assetflow_root"
              action="action_assetflow_audit"
              sequence="6"
              groups="assetflow.group_assetflow_manager"/>

    <!-- Reports -->
    <menuitem id="menu_assetflow_reports"
              name="Reports"
              parent="menu_assetflow_root"
              sequence="7"
              groups="assetflow.group_assetflow_manager"/>

    <menuitem id="menu_assetflow_report_assets"
              name="Asset Report"
              parent="menu_assetflow_reports"
              action="action_assetflow_report_asset"
              sequence="1"/>

    <menuitem id="menu_assetflow_report_allocation"
              name="Allocation Report"
              parent="menu_assetflow_reports"
              action="action_assetflow_report_allocation"
              sequence="2"/>

    <menuitem id="menu_assetflow_report_maintenance"
              name="Maintenance Report"
              parent="menu_assetflow_reports"
              action="action_assetflow_report_maintenance"
              sequence="3"/>

</odoo>
