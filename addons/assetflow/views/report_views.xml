<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Asset Report Action -->
    <record id="action_assetflow_report_asset" model="ir.actions.act_window">
        <field name="name">Asset Report</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>

    <!-- Allocation Report Action -->
    <record id="action_assetflow_report_allocation" model="ir.actions.act_window">
        <field name="name">Allocation Report</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'active')]</field>
    </record>

    <!-- Maintenance Report Action -->
    <record id="action_assetflow_report_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance Report</field>
        <field name="res_model">assetflow.maintenance</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
