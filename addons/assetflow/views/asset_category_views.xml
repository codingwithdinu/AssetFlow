<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Category Tree -->
    <record id="view_assetflow_category_tree" model="ir.ui.view">
        <field name="name">assetflow.category.tree</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <tree string="Asset Categories">
                <field name="code"/>
                <field name="name"/>
                <field name="depreciation_years"/>
                <field name="asset_count"/>
            </tree>
        </field>
    </record>

    <!-- Category Form -->
    <record id="view_assetflow_category_form" model="ir.ui.view">
        <field name="name">assetflow.category.form</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Category Name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="depreciation_years"/>
                            <field name="asset_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_assetflow_category" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="res_model">assetflow.category</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
