<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Allocation Tree -->
    <record id="view_assetflow_allocation_tree" model="ir.ui.view">
        <field name="name">assetflow.allocation.tree</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <tree string="Allocations"
                  decoration-success="state == 'active'"
                  decoration-muted="state in ('returned', 'cancelled')">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="allocation_date"/>
                <field name="expected_return_date"/>
                <field name="actual_return_date"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'returned'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Allocation Form -->
    <record id="view_assetflow_allocation_form" model="ir.ui.view">
        <field name="name">assetflow.allocation.form</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <form string="Asset Allocation">
                <header>
                    <button name="action_allocate" string="✅ Allocate"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_return" string="↩ Return Asset"
                            type="object" class="btn-warning"
                            attrs="{'invisible': [('state', '!=', 'active')]}"/>
                    <button name="action_cancel" string="✕ Cancel"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('state', 'not in', ['draft'])]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,returned"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Asset">
                            <field name="asset_id"/>
                        </group>
                        <group string="Employee">
                            <field name="employee_id"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Dates">
                            <field name="allocation_date"/>
                            <field name="expected_return_date"/>
                            <field name="actual_return_date" readonly="1"/>
                        </group>
                        <group string="Details">
                            <field name="purpose"/>
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_assetflow_allocation" model="ir.actions.act_window">
        <field name="name">Allocations</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first allocation!
            </p>
            <p>Assign assets to employees with full lifecycle tracking.</p>
        </field>
    </record>

</odoo>
