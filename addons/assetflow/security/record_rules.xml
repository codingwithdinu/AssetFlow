<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Employees can only see their own allocations -->
        <record id="rule_allocation_employee_own" model="ir.rule">
            <field name="name">Allocation: Employee sees own allocations</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Asset Managers see all allocations -->
        <record id="rule_allocation_manager_all" model="ir.rule">
            <field name="name">Allocation: Manager sees all</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_manager'))]"/>
        </record>

        <!-- Employees can only see their own bookings -->
        <record id="rule_booking_employee_own" model="ir.rule">
            <field name="name">Booking: Employee sees own bookings</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Asset Managers see all bookings -->
        <record id="rule_booking_manager_all" model="ir.rule">
            <field name="name">Booking: Manager sees all</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_manager'))]"/>
        </record>

    </data>
</odoo>
