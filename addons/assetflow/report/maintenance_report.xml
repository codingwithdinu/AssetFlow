<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PDF Report: Maintenance -->
    <record id="report_assetflow_maintenance_pdf" model="ir.actions.report">
        <field name="name">Maintenance Report</field>
        <field name="model">assetflow.maintenance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">assetflow.report_maintenance_template</field>
        <field name="report_file">assetflow.report_maintenance_template</field>
        <field name="binding_model_id" ref="model_assetflow_maintenance"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_maintenance_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>AssetFlow – Maintenance Report</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Asset</th>
                                <th>Reported By</th>
                                <th>Priority</th>
                                <th>Request Date</th>
                                <th>Completion Date</th>
                                <th>Cost (₹)</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="mnt">
                                <tr>
                                    <td><t t-esc="mnt.name"/></td>
                                    <td><t t-esc="mnt.asset_id.name"/></td>
                                    <td><t t-esc="mnt.reported_by.name"/></td>
                                    <td><t t-esc="mnt.priority"/></td>
                                    <td><t t-esc="mnt.request_date"/></td>
                                    <td><t t-esc="mnt.completion_date or '-'"/></td>
                                    <td><t t-esc="mnt.repair_cost"/></td>
                                    <td><t t-esc="mnt.state"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
