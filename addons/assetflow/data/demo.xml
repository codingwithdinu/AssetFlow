<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Demo Departments -->
        <record id="demo_dept_engineering" model="assetflow.department">
            <field name="name">Engineering</field>
            <field name="code">ENG</field>
            <field name="location">Floor 2, Block A</field>
        </record>

        <record id="demo_dept_hr" model="assetflow.department">
            <field name="name">Human Resources</field>
            <field name="code">HR</field>
            <field name="location">Floor 1, Block B</field>
        </record>

        <record id="demo_dept_finance" model="assetflow.department">
            <field name="name">Finance</field>
            <field name="code">FIN</field>
            <field name="location">Floor 3, Block A</field>
        </record>

        <!-- Demo Categories -->
        <record id="demo_cat_laptop" model="assetflow.category">
            <field name="name">Laptop</field>
            <field name="code">LAP</field>
            <field name="depreciation_years">3</field>
        </record>

        <record id="demo_cat_vehicle" model="assetflow.category">
            <field name="name">Vehicle</field>
            <field name="code">VEH</field>
            <field name="depreciation_years">10</field>
        </record>

        <record id="demo_cat_furniture" model="assetflow.category">
            <field name="name">Furniture</field>
            <field name="code">FRN</field>
            <field name="depreciation_years">8</field>
        </record>

        <record id="demo_cat_projector" model="assetflow.category">
            <field name="name">Projector</field>
            <field name="code">PRJ</field>
            <field name="depreciation_years">5</field>
        </record>

        <!-- Demo Employees -->
        <record id="demo_emp_john" model="assetflow.employee">
            <field name="name">John Smith</field>
            <field name="employee_id">EMP001</field>
            <field name="email">john.smith@company.com</field>
            <field name="job_title">Software Engineer</field>
            <field name="department_id" ref="demo_dept_engineering"/>
        </record>

        <record id="demo_emp_alice" model="assetflow.employee">
            <field name="name">Alice Johnson</field>
            <field name="employee_id">EMP002</field>
            <field name="email">alice.johnson@company.com</field>
            <field name="job_title">HR Manager</field>
            <field name="department_id" ref="demo_dept_hr"/>
        </record>

        <!-- Demo Assets -->
        <record id="demo_asset_dell" model="assetflow.asset">
            <field name="name">Dell Latitude 5540</field>
            <field name="category_id" ref="demo_cat_laptop"/>
            <field name="brand">Dell</field>
            <field name="serial_number">DL-SN-001</field>
            <field name="department_id" ref="demo_dept_engineering"/>
            <field name="purchase_date" eval="(datetime.date.today() - datetime.timedelta(days=365)).strftime('%Y-%m-%d')"/>
            <field name="purchase_price">75000</field>
            <field name="state">available</field>
        </record>

        <record id="demo_asset_macbook" model="assetflow.asset">
            <field name="name">MacBook Pro M3</field>
            <field name="category_id" ref="demo_cat_laptop"/>
            <field name="brand">Apple</field>
            <field name="serial_number">AP-SN-001</field>
            <field name="department_id" ref="demo_dept_engineering"/>
            <field name="purchase_date" eval="(datetime.date.today() - datetime.timedelta(days=180)).strftime('%Y-%m-%d')"/>
            <field name="purchase_price">150000</field>
            <field name="state">available</field>
        </record>

        <record id="demo_asset_projector" model="assetflow.asset">
            <field name="name">Epson EB-X51 Projector</field>
            <field name="category_id" ref="demo_cat_projector"/>
            <field name="brand">Epson</field>
            <field name="serial_number">EP-SN-001</field>
            <field name="department_id" ref="demo_dept_hr"/>
            <field name="purchase_date" eval="(datetime.date.today() - datetime.timedelta(days=730)).strftime('%Y-%m-%d')"/>
            <field name="purchase_price">45000</field>
            <field name="state">available</field>
        </record>

    </data>
</odoo>
